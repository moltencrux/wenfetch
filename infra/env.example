# Copy to .env and fill in values before deploying

# Django
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1,::1

# Caddy / network
# Hostname Caddy will serve (must match your DNS or /etc/hosts entry)
SERVER_HOSTNAME=localhost
# Ports to expose on the host
HTTP_PORT=8080
HTTPS_PORT=8443
# TLS mode: 'internal' for self-signed, or empty for Let's Encrypt (needs real domain)
TLS_MODE=internal

# Gunicorn tuning (optional)
# GUNICORN_CMD_ARGS=--timeout 120 --keep-alive 30 --log-level info
