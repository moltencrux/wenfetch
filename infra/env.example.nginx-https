# nginx with HTTPS — requires SSL certificate files on the host.
# For self-signed certs:
#   openssl req -x509 -newkey rsa:4096 -keyout server.key -out server.crt \
#     -days 365 -nodes -subj "/CN=yourhostname" \
#     -addext "subjectAltName=DNS:yourhostname"
# For Let's Encrypt certs, use certbot on the host first.
#
# 1. Copy to .env:  cp .env.example.nginx-https .env
# 2. Set DJANGO_SECRET_KEY, SERVER_HOSTNAME, SSL_CERT, SSL_KEY
# 3. Run: docker compose -f docker-compose.yaml -f docker-compose.nginx.yaml up -d
# 4. Run: docker compose exec web python manage.py migrate
# 5. Run: docker compose exec web python manage.py createsuperuser

COMPOSE_FILE=docker-compose.yaml:docker-compose.nginx.yaml

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# DJANGO_DEBUG=False
# ALLOWED_HOSTS=localhost,127.0.0.1,::1

# nginx
# SERVER_HOSTNAME=localhost
# HTTP_PORT=8080
# HTTPS_PORT=8443

# Absolute paths to SSL cert and key on the host machine
SSL_CERT=/path/to/server.crt
SSL_KEY=/path/to/server.key

# Must match the URL you access the site from
CSRF_TRUSTED_ORIGINS=https://localhost:8443
