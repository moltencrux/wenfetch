# Caddy with automatic self-signed HTTPS — works out of the box on a local network.
# 1. Copy to .env:  cp .env.example.caddy .env
# 2. Set DJANGO_SECRET_KEY
# 3. Set SERVER_HOSTNAME to your machine's hostname or IP
# 4. Run: docker compose -f docker-compose.yaml -f docker-compose.caddy.yaml up -d
# 5. Run: docker compose exec web python manage.py migrate
# 6. Run: docker compose exec web python manage.py createsuperuser
# 7. Trust Caddy's root CA in your browser (see README)

COMPOSE_FILE=docker-compose.yaml:docker-compose.caddy.yaml

# Django
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False

# Hostnames Django will accept requests for.
# Leading dot matches all subdomains. * matches everything.
# ALLOWED_HOSTS=localhost,127.0.0.1,::1
ALLOWED_HOSTS=*

# Caddy
# Hostname Caddy issues the certificate for — must match what you type in the browser
SERVER_HOSTNAME=localhost
# HTTP_PORT=8080
# HTTPS_PORT=8443
# TLS_MODE=internal

# Must match the URL you access the site from (including port if non-standard)
CSRF_TRUSTED_ORIGINS=https://localhost:8443
