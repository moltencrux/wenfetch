# nginx plain HTTP — simplest setup, no SSL, good for initial testing.
# 1. Copy to .env:  cp .env.example.nginx-http .env
# 2. Set DJANGO_SECRET_KEY
# 3. Run: docker compose -f docker-compose.yaml -f docker-compose.nginx-http.yaml up -d
# 4. Run: docker compose exec web python manage.py migrate
# 5. Run: docker compose exec web python manage.py createsuperuser
# Note: no HTTPS, do not use on a public network.

COMPOSE_FILE=docker-compose.yaml:docker-compose.nginx-http.yaml

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# DJANGO_DEBUG=False
ALLOWED_HOSTS=*

# nginx
SERVER_HOSTNAME=localhost
# HTTP_PORT=8080

# No CSRF_TRUSTED_ORIGINS needed for plain HTTP
